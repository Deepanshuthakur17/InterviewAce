generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String   @id @default(cuid())
  name               String?
  email              String   @unique
  password           String?
  avatar             String?
  skills             String[]
  careerGoals        String?
  resumeName         String?
  resumeParsedSkills String[]
}

model HistoryItem {
  id                String   @id @default(cuid())
  userId            String
  roleId            String
  roleTitle         String
  date              String
  durationSpent     Int
  totalQuestions    Int
  answeredQuestions Int
}
